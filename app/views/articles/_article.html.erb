<div data-controller="visitor" data-action="click->visitor#pageVisit" data-visitor-url-value="<%= article_path(article) %>" class="py-2 md:py-4 space-y-3 border-b border-gray-200 cursor-pointer">
    <div data-controller="timestamp" class="inline-flex space-x-1 text-sm">
        <span class="py-1 px-1.5 flex items-center align-middle text-gray-600 bg-gray-50 border border-transparent rounded-md space-x-1.5">
            <span class="">
                <%= lucide_icon('clock-4', class: 'size-4') %>
            </span>
            <span data-timestamp-target="date" class=""><%= article.updated_at %></span>
        </span>
    </div>
    <div class="">
        <span class="font-bold text-2xl sm:text-3xl">
            <%= article.title.blank? ? article.blank_title : article.title %>
        </span>
    </div>
</div>