<div class="justify-evenly flex flex-row">
    <div class="min-w-[0px] lg:min-w-[728px] lg:max-w-[728px] grow shrink basis-auto block min-h-[100vh]">
        <div class="flex justify-center">
            <div class="min-w-[0px] max-w-[680px] w-full sm:mx-8">
                <div class="w-full sm:border sm:border-gray-100 sm:rounded-lg px-4 sm:px-14 pb-4 sm:pb-4 pt-4 sm:pt-6 space-y-4">
                    <div class="w-full text-center">
                        <p class="font-bold text-2xl">Settings</p>
                    </div>
                    <div class="w-full border border-gray-200 bg-white rounded-lg px-4 sm:px-6 py-6">
                        <div data-controller="noform" data-noform-form-scope-value="binder" data-noform-update-url-value="<%= editors_binder_title_path(@binder) %>" class="space-y-6">
                            <div class="flex items-center justify-between">
                                <div class="">
                                    <span class="font-semibold">Basic</span>
                                </div>
                                <div class="">
                                    <button data-action="click->noform#updateForm" data-noform-target="save" class="text-sm text-blue-700 hover:text-purple-700 disabled:text-gray-600 underline hover:no-underline disabled:no-underline font-normal cursor-pointer disabled:cursor-not-allowed">
                                        Save
                                    </button>
                                </div>
                            </div>
                
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <label class="block text-sm font-medium text-gray-700">Title</label>
                                    <div class="bg-gray-100 rounded-md py-2 px-3 border border-transparent focus-within:bg-white focus-within:border-gray-800 ">
                                        <input type="text" name="title" data-noform-target="input" data-field="title" value="<%= @binder.title %>" class="w-full bg-transparent border-none p-0 focus:ring-0 focus:outline-0">
                                    </div>
                                </div>
                
                                <div class="space-y-2">
                                    <label class="block text-sm font-medium text-gray-700">Description</label>
                                    <div class="bg-gray-100 rounded-md py-2 px-3 border border-transparent focus-within:bg-white focus-within:border-gray-800 ">
                                        <textarea name="description" data-noform-target="input" data-field="description" rows="4" data-controller="textarea-autogrow" class="resize-none block w-full bg-transparent border-none p-0 focus:ring-0 focus:outline-0"><%= @binder.description %></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="w-full border border-gray-200 bg-white rounded-lg px-4 sm:px-6 py-6 space-y-6">
                        <div class="flex items-center justify-between">
                            <div class="">
                                <span class="font-semibold">Visibility</span>
                            </div>
                            <div class="">
                                <span class="text-sm text-gray-400">Autosave</span>
                            </div>
                        </div>
            
                        <div data-controller="selector" class="">
                            <div data-selector-target="skeleton" class="animate-pulse">
                                <div class="h-10 w-full bg-gray-200 rounded"></div>
                            </div>
                            <div data-selector-target="content" data-controller="visible" data-visible-url-value="<%= editors_binder_visible_path(@binder) %>" data-visible-current-value="<%= @binder.status %>" data-visible-form-scope-value="binder" class="hidden">
                                <select data-visible-target="input" data-field="status" data-action="change->visible#changeStatus" class="block w-full py-1.5 rounded-md border-transparent bg-gray-100 focus:border-transparent focus:ring-transparent text-xl font-semibold capitalize">
                                    <% Article.statuses.keys.each do |status| %>
                                        <option value="<%= status %>" <%= 'selected' if @binder.status == status %>>
                                            <%= editor_binder_settings_status(status) %>
                                        </option>
                                    <% end %>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="w-full border border-gray-200 bg-white rounded-lg px-4 sm:px-6 py-6 space-y-6">
                        <div class="flex items-center justify-between">
                            <div class="">
                                <span class="font-semibold">Deletion</span>
                            </div>
                            <div class="">
                                <span class="text-sm text-gray-400"></span>
                            </div>
                        </div>
            
                        <div class="">
                            <%= link_to editors_binder_delete_path(@binder), data: { turbo_frame: "modal" }, class: "" do %>
                                <div class="px-2 py-1 flex justify-center items-center font-semibold text-lg text-white shadow-sm rounded-md bg-red-600 hover:bg-red-500 hover:cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 disabled:cursor-not-allowed disabled:bg-red-300">
                                    <span class="flex items-center space-x-2">
                                        <span class="">
                                            <%= lucide_icon('trash', 'class': 'size-5') %>
                                        </span>
                                        <span class="">
                                            Delete Binder
                                        </span>
                                    </span>
                                </div>
                            <% end %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>