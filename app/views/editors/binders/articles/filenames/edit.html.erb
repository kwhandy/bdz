<%= turbo_frame_tag "sL_#{@article.uid}" do %>
    <div data-controller="noform" data-noform-form-scope-value="article" data-noform-update-url-value="<%= editors_binder_article_filename_path(@binder, @article) %>" class="space-y-6">
        <div class="flex items-center justify-between">
            <div class="">
                <%= link_to editors_binder_article_settings_path(@binder, @article), data: { turbo_frame: "sL_#{@article.uid}"}, class: "btn_rv btn_bs" do %>
                    <%= lucide_icon('arrow-left', class: 'size-5') %>
                <% end %>
            </div>
            <div class="">
                <button data-action="click->noform#updateForm" data-noform-target="save" class="hover:cursor-pointer disabled:cursor-not-allowed disabled:bg-blue-300 rounded-full bg-blue-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600">
                    Save
                </button>
            </div>
        </div>
        <div class="space-y-4">
            <div class="">
                <p class="text-2xl font-bold">Filename</p>
            </div>

            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Title</label>
                    
                    <div class="bg-gray-100 rounded-md py-2 px-3 border border-transparent focus-within:bg-white focus-within:border-gray-800 ">
                        <input type="text" name="title" data-noform-target="input" data-field="title" value="<%= @article.title %>" class="w-full bg-transparent border-none p-0 focus:ring-0 focus:outline-0">
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-medium text-gray-700">Subtitle</label>

                    <div class="bg-gray-100 rounded-md py-2 px-3 border border-transparent focus-within:bg-white focus-within:border-gray-800 ">
                        <input type="text" name="subtitle" data-noform-target="input" data-field="subtitle" value="<%= @article.subtitle %>" class="w-full bg-transparent border-none p-0 focus:ring-0 focus:outline-0">
                    </div>
                </div>
            </div>
        </div>
    </div>
<% end %>