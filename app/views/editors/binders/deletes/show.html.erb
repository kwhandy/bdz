<%= render Shared::ModalComponent.new(advance_history: false, auto_close: false, close_button: false) do %>
    <div class="h-dvh sm:h-fit w-full sm:w-96">
        <div data-controller="confirmation" class="space-y-6">
            <div class="flex items-center justify-between">
                <div class="">
                    <%= content_tag "button",
                        type: "button",
                        aria: { label: "close" },
                        class: "btn_rv btn_bs",
                        data: { action: "modal#hideModal" } do %>
                        <%= lucide_icon('x', class: 'size-5') %>
                    <% end %>
                </div>
                <div class="">
                    <button type="submit" form="confirmDelete" data-confirmation-target="item" disabled="" class="hover:cursor-pointer disabled:cursor-not-allowed disabled:bg-red-300 rounded-full bg-red-600 px-3 py-1 text-sm font-semibold text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600">
                        Delete
                    </button>
                </div>
            </div>
            <div class="space-y-4">
                <div class="">
                    <p class="text-2xl font-bold">Delete</p>
                </div>
                <div>
                    <%= form_with(url: editors_binder_delete_path(@binder), method: :delete, data: { controller: "" }, id: "confirmDelete", class: "space-y-3") do |f| %>
                        <div class="space-y-2">
                            <label for="confirmation" class="block text-sm/6 font-medium text-gray-900">
                                Are you sure to permanently delete this binder? because this action will also delete all articles associated with it
                            </label>
                            <div>
                                <div class="bg-gray-100 rounded-md py-2 px-3 border border-transparent focus-within:bg-white focus-within:border-gray-800 ">
                                    <input id="confirmation" type="text" data-confirmation-target="input" data-confirmation-content="DELETE" data-action="confirmation#check" autocomplete="off" class="w-full bg-transparent border-none p-0 focus:ring-0 focus:outline-0" placeholder="Type `DELETE` to confirm">
                                </div>
                            </div>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
<% end %>